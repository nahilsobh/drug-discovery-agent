Bootstrap: docker
From: rockylinux:8

%labels
    Maintainer RedClaw AI Factory
    Version 1.0
    Description Drug Discovery Agent — Claude ReAct loop + GenomeClaw GPU API

%help
    RedClaw AI Factory Strategic Discovery Agent.
    Requires:
      --bind <project_dir>:/app
      GenomeClaw binary bind-mounted via host (clawapi launched outside container)
      ANTHROPIC_API_KEY or ANTHROPIC_AUTH_TOKEN passed via --env

    Example (interactive):
      singularity exec --cleanenv --bind /path/to/project:/app \
        --env ANTHROPIC_AUTH_TOKEN=$ANTHROPIC_AUTH_TOKEN \
        drug-discovery-agent.sif python3 run_agent.py "CEO briefing query"

    Example (SLURM GPU):
      sbatch ceo_query_slurm.sh

%environment
    export PYTHONPATH=/app
    export PYTHONUNBUFFERED=1
    export LANG=en_US.UTF-8
    export LC_ALL=en_US.UTF-8

%post
    # ── System packages ──────────────────────────────────────────────────────────
    dnf -y update
    dnf -y install epel-release
    dnf -y install \
        python39 python39-pip python39-devel \
        gcc gcc-c++ make \
        curl wget git \
        libffi-devel openssl-devel \
        bzip2 bzip2-devel xz-devel zlib-devel \
        libgomp \
        && dnf clean all

    # Symlink python3 → python3.9 (RockyLinux 8 ships python3.6 as default)
    ln -sf /usr/bin/python3.9 /usr/local/bin/python3
    ln -sf /usr/bin/pip3.9    /usr/local/bin/pip3

    # ── Python dependencies ──────────────────────────────────────────────────────
    python3 -m pip install --upgrade pip setuptools wheel

    # Core agent requirements (versions pinned for reproducibility)
    python3 -m pip install \
        "anthropic>=0.52"   \
        "requests>=2.31"    \
        "arxiv>=2.1"        \
        "reportlab>=4.1"    \
        "pyyaml>=6.0"       \
        "httpx>=0.27"

    # ── Cleanup ──────────────────────────────────────────────────────────────────
    python3 -m pip cache purge
    dnf clean all
    rm -rf /tmp/* /var/cache/dnf

%runscript
    exec python3 /app/run_agent.py "$@"
